# Solana RPC
RPC_URL=https://api.mainnet-beta.solana.com
RPC_WS_URL=
COMMITMENT=confirmed

# Wallet. Required only when AUTO_OPEN=true or when exits must be sent.
# Accepted formats: base58 secret key or JSON array secret key.
WALLET_PRIVATE_KEY=

# Runtime safety
AUTO_OPEN=false
AUTO_OPEN_TARGET_POSITIONS=1
AUTO_REOPEN_AFTER_EXIT=true
AUTO_REOPEN_DELAY_MS=5000
POSITION_STORE_PATH=./data/positions.json
MAX_OPEN_POSITIONS=10
MONITOR_INTERVAL_MS=30000
MONITOR_CONCURRENCY=3
OUT_OF_RANGE_UP_EXIT_ENABLED=true
OUT_OF_RANGE_UP_COOLDOWN_MS=300000
TAKE_PROFIT_PCT=5
STOP_LOSS_PCT=-12

# Entry sizing.
# wallet-ratio sizes the next position from wallet SOL balance + active LP exposure.
# fixed uses ENTRY_TOKEN_X_AMOUNT_UI / ENTRY_TOKEN_Y_AMOUNT_UI directly.
ENTRY_SIZING_MODE=wallet-ratio
ENTRY_TOKEN_X_AMOUNT_UI=0
ENTRY_TOKEN_Y_AMOUNT_UI=0
ENTRY_WALLET_ALLOCATION_PCT=25
ENTRY_RESERVE_SOL_PCT=10
ENTRY_MIN_POSITION_SOL_PCT=4
ENTRY_MAX_POSITION_SOL_PCT=20
ENTRY_MAX_TOTAL_EXPOSURE_PCT=70
ENTRY_REQUIRE_SOL_POOL=true
ENTRY_SOL_ONLY=true

# Optional absolute guards in SOL. Keep 0 to let wallet ratios drive sizing.
ENTRY_MIN_SOL_RESERVE=0
ENTRY_MIN_POSITION_SOL=0
ENTRY_MAX_POSITION_SOL=0

BID_ASK_RANGE_BINS=69
ENTRY_SLIPPAGE_PCT=0.5

# Transactions
PRIORITY_FEE_MICRO_LAMPORTS=25000
COMPUTE_UNIT_LIMIT=1400000
TX_MAX_RETRIES=5
TX_CONFIRM_TIMEOUT_MS=15000
SKIP_PREFLIGHT=false

# Pool scanner
METEORA_DATA_API_BASE=https://dlmm.datapi.meteora.ag
SCANNER_PAGE_SIZE=100
SCANNER_CANDIDATE_LIMIT=40
SCANNER_MIN_TVL_USD=10000
SCANNER_MIN_VOLUME_24H_USD=50000
SCANNER_REQUIRE_TOKEN_VERIFIED=true
SCANNER_ALLOW_UNVERIFIED_IF_JUPITER_PASSES=true
SCANNER_SORT_BY=fee_tvl_ratio_24h:desc
SCANNER_DISCOVERY_SORTS=fee_tvl_ratio_1h:desc,fee_tvl_ratio_30m:desc,pool_created_at:desc
SCANNER_DISCOVERY_MAX_POOL_AGE_HOURS=12
SCANNER_DISCOVERY_MIN_TVL_USD=5000
SCANNER_DISCOVERY_MIN_VOLUME_30M_USD=5000
SCANNER_DISCOVERY_MIN_VOLUME_1H_USD=10000
SCANNER_DISCOVERY_MIN_FEE_TVL_RATIO_30M=0.35
SCANNER_DISCOVERY_MIN_FEE_TVL_RATIO_1H=0.7

# Risk providers
RUGCHECK_API_BASE=https://api.rugcheck.xyz
RUGCHECK_API_KEY=
RUGCHECK_MAX_NORMALIZED_SCORE=45
RUGCHECK_FAIL_CLOSED=true

# Optional enrichers
DEXSCREENER_API_BASE=https://api.dexscreener.com
DEXSCREENER_ENABLED=true

# Jupiter Tokens V2. Official paid host is https://api.jup.ag/tokens/v2 with x-api-key.
# The lite host is useful for local development.
JUPITER_TOKEN_API_BASE=https://lite-api.jup.ag/tokens/v2
JUPITER_SWAP_API_BASE=https://lite-api.jup.ag/swap/v1
JUPITER_API_KEY=
JUPITER_ENABLED=true
JUPITER_FAIL_CLOSED=true
JUPITER_MIN_ORGANIC_SCORE=45
JUPITER_HIGH_CONFIDENCE_ORGANIC_SCORE=70
JUPITER_MIN_LIQUIDITY_USD=10000
JUPITER_MIN_HOLDER_COUNT=100
JUPITER_MAX_TOP_HOLDERS_PCT=35
JUPITER_MAX_DEV_BALANCE_PCT=8
JUPITER_REQUIRE_MINT_AUTHORITY_DISABLED=true
JUPITER_REQUIRE_FREEZE_AUTHORITY_DISABLED=true

# After a DLMM exit, swap recovered non-SOL pool tokens back to SOL.
POST_EXIT_SWAP_TO_SOL=true
POST_EXIT_SWAP_MIN_USD=0.25
POST_EXIT_SWAP_SLIPPAGE_BPS=150
POST_EXIT_SWAP_RESTRICT_INTERMEDIATE_TOKENS=true

# Local paper-trading dashboard
WEB_PORT=8787
WEB_HOST=127.0.0.1
PAPER_STATE_PATH=./data/paper-state.json
PAPER_STARTING_BALANCE_USD=10000
PAPER_POSITION_SIZE_USD=500
PAPER_MAX_POSITIONS=10
PAPER_SCAN_INTERVAL_MS=60000
PAPER_TAKE_PROFIT_PCT=5
PAPER_STOP_LOSS_PCT=-12
PAPER_MAX_FEE_RATE_PER_HOUR_PCT=3
