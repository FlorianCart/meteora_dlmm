{
  "name": "meteora-dlmm-trading-bot",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "description": "Automated TypeScript/Solana bot for Meteora DLMM pool discovery, bid/ask liquidity entry, position monitoring and take-profit exits.",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "web": "tsx src/web/server.ts",
    "scan": "tsx src/index.ts --scan",
    "monitor": "tsx src/index.ts --monitor",
    "start": "node dist/index.js",
    "start:scan": "node dist/index.js --scan",
    "start:monitor": "node dist/index.js --monitor",
    "start:web": "node dist/web/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@coral-xyz/anchor": "0.31.0",
    "@meteora-ag/dlmm": "1.9.10",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^5.0.0",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.7",
    "express": "^4.19.2",
    "p-limit": "^3.1.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/express": "^4.17.21",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
